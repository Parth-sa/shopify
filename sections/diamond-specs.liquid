{% comment %}
  DIAMOND SPECS SECTION
  =====================
  Premium display for diamond specifications (4Cs)
{% endcomment %}

{{ 'diamond-specs.css' | asset_url | stylesheet_tag }}

{% style %}
  #DiamondSpecs-{{ section.id }} {
    --specs-bg: {{ section.settings.background_color }};
    --specs-text: {{ section.settings.text_color }};
    --specs-accent: {{ section.settings.accent_color }};
    --specs-border: {{ section.settings.border_color }};
  }
{% endstyle %}

<section 
  id="DiamondSpecs-{{ section.id }}"
  class="diamond-specs"
  style="background-color: var(--specs-bg); color: var(--specs-text);"
>
  <div class="luxury-container">
    <!-- Section Header -->
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="diamond-specs__header">
        {%- if section.settings.subheading != blank -%}
          <span class="diamond-specs__label">{{ section.settings.subheading }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="diamond-specs__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <p class="diamond-specs__description">{{ section.settings.description }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <!-- 4Cs Grid -->
    <div class="diamond-specs__grid">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'spec_card' -%}
            <div class="diamond-specs__card" {{ block.shopify_attributes }}>
              <div class="diamond-specs__card-inner">
                {%- if block.settings.icon != blank -%}
                  <div class="diamond-specs__icon">
                    <img 
                      src="{{ block.settings.icon | image_url: width: 120 }}"
                      alt="{{ block.settings.title }}"
                      width="60"
                      height="60"
                      loading="lazy"
                    >
                  </div>
                {%- elsif block.settings.svg_icon != blank -%}
                  <div class="diamond-specs__icon diamond-specs__icon--svg">
                    {{ block.settings.svg_icon }}
                  </div>
                {%- else -%}
                  <!-- Default Icons based on Title -->
                  <div class="diamond-specs__icon diamond-specs__icon--default">
                    {%- if block.settings.title contains 'Carat' -%}
                      <svg viewBox="0 0 60 60" fill="none" stroke="currentColor" stroke-width="1.5">
                        <circle cx="30" cy="30" r="20"/>
                        <circle cx="30" cy="30" r="10"/>
                        <path d="M30 10v8M30 42v8M10 30h8M42 30h8"/>
                      </svg>
                    {%- elsif block.settings.title contains 'Cut' -%}
                      <svg viewBox="0 0 60 60" fill="none" stroke="currentColor" stroke-width="1.5">
                        <polygon points="30,5 50,20 45,50 15,50 10,20"/>
                        <polyline points="10,20 30,35 50,20"/>
                        <line x1="30" y1="35" x2="30" y2="50"/>
                        <line x1="15" y1="50" x2="30" y2="35"/>
                        <line x1="45" y1="50" x2="30" y2="35"/>
                      </svg>
                    {%- elsif block.settings.title contains 'Color' -%}
                      <svg viewBox="0 0 60 60" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M30 5L55 25L47 55H13L5 25L30 5Z"/>
                        <circle cx="30" cy="30" r="8"/>
                      </svg>
                    {%- elsif block.settings.title contains 'Clarity' -%}
                      <svg viewBox="0 0 60 60" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M30 5L50 20V45L30 55L10 45V20L30 5Z"/>
                        <circle cx="30" cy="30" r="12"/>
                        <path d="M24 30l4 4 8-8"/>
                      </svg>
                    {%- else -%}
                      <svg viewBox="0 0 60 60" fill="none" stroke="currentColor" stroke-width="1.5">
                        <polygon points="30,5 50,20 45,50 15,50 10,20"/>
                      </svg>
                    {%- endif -%}
                  </div>
                {%- endif -%}

                <h3 class="diamond-specs__card-title">{{ block.settings.title }}</h3>

                {%- if block.settings.value != blank -%}
                  <div class="diamond-specs__value">{{ block.settings.value }}</div>
                {%- endif -%}

                {%- if block.settings.grade != blank -%}
                  <div class="diamond-specs__grade">{{ block.settings.grade }}</div>
                {%- endif -%}

                {%- if block.settings.description != blank -%}
                  <p class="diamond-specs__card-text">{{ block.settings.description }}</p>
                {%- endif -%}

                {%- if block.settings.show_scale -%}
                  <div class="diamond-specs__scale">
                    <div class="diamond-specs__scale-bar">
                      <div 
                        class="diamond-specs__scale-fill" 
                        style="width: {{ block.settings.scale_value }}%;"
                      ></div>
                      <div 
                        class="diamond-specs__scale-marker" 
                        style="left: {{ block.settings.scale_value }}%;"
                      ></div>
                    </div>
                    <div class="diamond-specs__scale-labels">
                      <span>{{ block.settings.scale_min }}</span>
                      <span>{{ block.settings.scale_max }}</span>
                    </div>
                  </div>
                {%- endif -%}
              </div>
            </div>

          {%- when 'certification' -%}
            <div class="diamond-specs__cert" {{ block.shopify_attributes }}>
              {%- if block.settings.cert_logo != blank -%}
                <img 
                  src="{{ block.settings.cert_logo | image_url: width: 200 }}"
                  alt="{{ block.settings.cert_name }}"
                  width="100"
                  height="auto"
                  loading="lazy"
                  class="diamond-specs__cert-logo"
                >
              {%- endif -%}
              <div class="diamond-specs__cert-content">
                <span class="diamond-specs__cert-label">Certified By</span>
                <h4 class="diamond-specs__cert-name">{{ block.settings.cert_name }}</h4>
                {%- if block.settings.cert_number != blank -%}
                  <span class="diamond-specs__cert-number">{{ block.settings.cert_number }}</span>
                {%- endif -%}
                {%- if block.settings.cert_link != blank -%}
                  <a href="{{ block.settings.cert_link }}" target="_blank" rel="noopener" class="diamond-specs__cert-link">
                    View Certificate
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                      <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                      <polyline points="15 3 21 3 21 9"/>
                      <line x1="10" y1="14" x2="21" y2="3"/>
                    </svg>
                  </a>
                {%- endif -%}
              </div>
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>

    <!-- Additional Info -->
    {%- if section.settings.show_info_section -%}
      <div class="diamond-specs__info">
        <div class="diamond-specs__info-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="12" cy="12" r="10"/>
            <path d="M12 16v-4M12 8h.01"/>
          </svg>
        </div>
        <div class="diamond-specs__info-text">
          {{ section.settings.info_text }}
        </div>
      </div>
    {%- endif -%}

    <!-- CTA Button -->
    {%- if section.settings.button_label != blank -%}
      <div class="diamond-specs__cta">
        <a href="{{ section.settings.button_link }}" class="luxury-btn luxury-btn--primary">
          {{ section.settings.button_label }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Diamond Specs",
  "tag": "section",
  "class": "diamond-specs-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Diamond Quality"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The 4Cs of Excellence"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Every diamond we select meets the highest standards of quality, cut, and brilliance."
    },
    {
      "type": "header",
      "content": "Additional Info"
    },
    {
      "type": "checkbox",
      "id": "show_info_section",
      "label": "Show info section",
      "default": true
    },
    {
      "type": "richtext",
      "id": "info_text",
      "label": "Info text",
      "default": "<p>All our diamonds are conflict-free and ethically sourced. Each stone comes with its own certificate of authenticity.</p>"
    },
    {
      "type": "header",
      "content": "Call to Action"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Learn More About Diamonds"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#0a0a0a"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#c9a962"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#e5e5e5"
    }
  ],
  "blocks": [
    {
      "type": "spec_card",
      "name": "Spec Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Custom icon image"
        },
        {
          "type": "html",
          "id": "svg_icon",
          "label": "Custom SVG icon",
          "info": "Paste SVG code here"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Carat"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "default": "1.52 ct"
        },
        {
          "type": "text",
          "id": "grade",
          "label": "Grade",
          "default": "Excellent"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "The standard unit of weight for diamonds and other gemstones."
        },
        {
          "type": "checkbox",
          "id": "show_scale",
          "label": "Show scale bar",
          "default": false
        },
        {
          "type": "range",
          "id": "scale_value",
          "min": 0,
          "max": 100,
          "step": 5,
          "default": 75,
          "label": "Scale position (%)"
        },
        {
          "type": "text",
          "id": "scale_min",
          "label": "Scale minimum label",
          "default": "Low"
        },
        {
          "type": "text",
          "id": "scale_max",
          "label": "Scale maximum label",
          "default": "High"
        }
      ]
    },
    {
      "type": "certification",
      "name": "Certification",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "cert_logo",
          "label": "Certification logo"
        },
        {
          "type": "text",
          "id": "cert_name",
          "label": "Certification name",
          "default": "GIA"
        },
        {
          "type": "text",
          "id": "cert_number",
          "label": "Certificate number"
        },
        {
          "type": "url",
          "id": "cert_link",
          "label": "Certificate link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Diamond Specs",
      "blocks": [
        {
          "type": "spec_card",
          "settings": {
            "title": "Carat",
            "value": "1.52 ct",
            "description": "The weight of the diamond, determining its size and rarity."
          }
        },
        {
          "type": "spec_card",
          "settings": {
            "title": "Cut",
            "value": "Excellent",
            "description": "The quality of angles, proportions, and symmetry that maximize brilliance."
          }
        },
        {
          "type": "spec_card",
          "settings": {
            "title": "Color",
            "value": "D-F",
            "grade": "Colorless",
            "description": "Graded on a scale from D (colorless) to Z (light yellow)."
          }
        },
        {
          "type": "spec_card",
          "settings": {
            "title": "Clarity",
            "value": "VVS1",
            "description": "The degree to which a diamond is free from inclusions and blemishes."
          }
        }
      ]
    }
  ]
}
{% endschema %}
