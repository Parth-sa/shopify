{{ 'ring-360-viewer.css' | asset_url | stylesheet_tag }}

<div
  class="ring-360-section section-{{ section.id }}"
  style="background-color: {{ section.settings.background_color }};"
>
  <div class="ring-360-container page-width">
    {% if section.settings.heading != blank %}
      <div class="ring-360-header">
        {% if section.settings.subheading != blank %}
          <span class="ring-360-subheading">{{ section.settings.subheading }}</span>
        {% endif %}
        <h2 class="ring-360-title">{{ section.settings.heading }}</h2>
        {% if section.settings.description != blank %}
          <p class="ring-360-description">{{ section.settings.description }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ring-360-content">
      <!-- Preview Image with 360 Button -->
      <div class="ring-360-preview">
        {% if section.settings.preview_image != blank %}
          <img
            src="{{ section.settings.preview_image | image_url: width: 800 }}"
            alt="{{ section.settings.heading | default: '360 Ring Viewer' }}"
            class="ring-360-preview-image"
            loading="lazy"
          >
        {% else %}
          <div class="ring-360-placeholder">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="80"
              height="80"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="12" cy="12" r="10"></circle>
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
              <line x1="2" y1="12" x2="22" y2="12"></line>
            </svg>
            <span>360° View</span>
          </div>
        {% endif %}

        <!-- 360 Button Overlay -->
        <button
          type="button"
          class="ring-360-button"
          data-360-trigger
          data-glb-url="{{ section.settings.glb_file_url }}"
          aria-label="Open 360 degree view"
        >
          <span class="ring-360-button-icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="12" cy="12" r="10"></circle>
              <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"></path>
              <path d="M2 12h20"></path>
            </svg>
          </span>
          <span class="ring-360-button-text">{{ section.settings.button_text | default: 'View in 360°' }}</span>
        </button>
      </div>

      {% if section.settings.show_features %}
        <div class="ring-360-features">
          <div class="ring-360-feature">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="M21 12a9 9 0 1 1-6.219-8.56"></path>
              <polyline points="22,4 12,14.01 9,11.01"></polyline>
            </svg>
            <span>Rotate 360°</span>
          </div>
          <div class="ring-360-feature">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
              <line x1="11" y1="8" x2="11" y2="14"></line>
              <line x1="8" y1="11" x2="14" y2="11"></line>
            </svg>
            <span>Zoom In/Out</span>
          </div>
          <div class="ring-360-feature">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="M14 9a2 2 0 0 1-2 2H6l-4 4V4c0-1.1.9-2 2-2h8a2 2 0 0 1 2 2v5Z"></path>
              <path d="M18 9h2a2 2 0 0 1 2 2v11l-4-4h-6a2 2 0 0 1-2-2v-1"></path>
            </svg>
            <span>Interactive View</span>
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>

<!-- 360 Viewer Modal -->
<div class="ring-360-modal" id="ring360Modal-{{ section.id }}" aria-hidden="true">
  <div class="ring-360-modal-overlay" data-360-close></div>
  <div class="ring-360-modal-container">
    <div class="ring-360-modal-header">
      <h3 class="ring-360-modal-title">{{ section.settings.modal_title | default: '360° Ring View' }}</h3>
      <button type="button" class="ring-360-modal-close" data-360-close aria-label="Close modal">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
    <div class="ring-360-modal-content">
      <div class="ring-360-viewer-wrapper">
        <!-- Model Viewer will be inserted here -->
        <div class="ring-360-loader" id="ring360Loader-{{ section.id }}">
          <div class="ring-360-spinner"></div>
          <p>Loading 3D model...</p>
        </div>
        
        {% if section.settings.viewer_type == 'webgi' %}
          <!-- WebGI Advanced Viewer (iframe) -->
          <iframe 
            id="ring360Viewer-{{ section.id }}"
            class="ring-360-webgi-iframe"
            src="{{ section.settings.webgi_viewer_url }}{% if section.settings.glb_file_url != blank %}?model={{ section.settings.glb_file_url | url_encode }}{% endif %}"
            frameborder="0"
            allowfullscreen
            allow="xr-spatial-tracking"
            style="width: 100%; height: 100%; min-height: 500px; border: none;"
          ></iframe>
        {% else %}
          <!-- Standard Model Viewer -->
          <model-viewer
            id="ring360Viewer-{{ section.id }}"
            class="ring-360-model-viewer"
            src="{{ section.settings.glb_file_url }}"
            alt="{{ section.settings.heading | default: 'Ring 3D Model' }}"
            camera-controls
            auto-rotate
            auto-rotate-delay="1000"
            rotation-per-second="30deg"
            interaction-prompt="auto"
            shadow-intensity="1"
            shadow-softness="1"
            exposure="{{ section.settings.exposure | default: 1 }}"
            environment-image="neutral"
            loading="eager"
            reveal="auto"
            ar
            ar-modes="webxr scene-viewer quick-look"
            touch-action="pan-y"
          >
            <div class="ring-360-viewer-controls" slot="interaction-prompt">
              <span>Drag to rotate • Pinch to zoom</span>
            </div>
          </model-viewer>
        {% endif %}
      </div>
    </div>
    <div class="ring-360-modal-footer">
      <div class="ring-360-instructions">
        <span><strong>Desktop:</strong> Click & drag to rotate, scroll to zoom</span>
        <span><strong>Mobile:</strong> Touch & drag to rotate, pinch to zoom</span>
      </div>
      {% if section.settings.show_ar_button %}
        <button type="button" class="ring-360-ar-button" id="arButton-{{ section.id }}">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"></path>
            <path d="m3.34 7h17.32M3.34 17h17.32"></path>
            <path d="M12 22c2.761 0 5-4.477 5-10S14.761 2 12 2s-5 4.477-5 10 2.239 10 5 10z"></path>
          </svg>
          View in AR
        </button>
      {% endif %}
    </div>
  </div>
</div>

<!-- Load Model Viewer Script -->
<script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/3.3.0/model-viewer.min.js"></script>

<script>
  (function () {
    const sectionId = '{{ section.id }}';
    const glbUrl = '{{ section.settings.glb_file_url }}';

    function initViewer() {
      const section = document.querySelector('.section-' + sectionId);
      if (!section) {
        console.error('360 Viewer: Section not found');
        return;
      }

      const trigger = section.querySelector('[data-360-trigger]');
      const modal = document.getElementById('ring360Modal-' + sectionId);
      const viewer = document.getElementById('ring360Viewer-' + sectionId);
      const loader = document.getElementById('ring360Loader-' + sectionId);
      const arButton = document.getElementById('arButton-' + sectionId);

      if (!modal || !viewer) {
        console.error('360 Viewer: Modal or viewer not found');
        return;
      }

      const closeButtons = modal.querySelectorAll('[data-360-close]');

      // Open modal
      if (trigger) {
        trigger.addEventListener('click', function (e) {
          e.preventDefault();
          console.log('360 button clicked, opening modal...');

          // Set the GLB source
          if (glbUrl && viewer.getAttribute('src') !== glbUrl) {
            viewer.setAttribute('src', glbUrl);
          }

          modal.classList.add('is-open');
          modal.setAttribute('aria-hidden', 'false');
          document.body.style.overflow = 'hidden';

          // Show loader
          if (loader) {
            loader.style.display = 'flex';
          }
        });
      }

      // Close modal
      closeButtons.forEach(function (btn) {
        btn.addEventListener('click', closeModal);
      });

      // Close on escape key
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && modal.classList.contains('is-open')) {
          closeModal();
        }
      });

      function closeModal() {
        modal.classList.remove('is-open');
        modal.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';

        // Stop auto-rotate when closed (only for model-viewer)
        if (viewer && viewer.tagName !== 'IFRAME' && viewer.autoRotate !== undefined) {
          viewer.autoRotate = false;
        }
      }

      // Check if using WebGI iframe or model-viewer
      const isWebGI = viewer && viewer.tagName === 'IFRAME';
      
      // Model viewer events (only for standard viewer)
      if (viewer && !isWebGI) {
        viewer.addEventListener('load', function () {
          console.log('3D model loaded successfully');
          if (loader) {
            loader.style.display = 'none';
          }
          viewer.autoRotate = true;
        });

        viewer.addEventListener('error', function (e) {
          console.error('Model viewer error:', e);
          if (loader) {
            loader.innerHTML = '<p style="color: #c00;">Error loading 3D model</p>';
          }
        });
      }
      
      // WebGI iframe events
      if (viewer && isWebGI) {
        viewer.addEventListener('load', function() {
          console.log('WebGI viewer loaded');
          if (loader) {
            loader.style.display = 'none';
          }
        });
      }

      // AR Button
      if (arButton && viewer) {
        arButton.addEventListener('click', function () {
          viewer.activateAR();
        });
      }

      console.log('360 Viewer initialized for section:', sectionId);
    }

    // Initialize when DOM is ready
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initViewer);
    } else {
      initViewer();
    }
  })();
</script>

{% schema %}
{
  "name": "Ring 360° Viewer",
  "tag": "section",
  "class": "ring-360-viewer-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Interactive Experience"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "View Our Ring in 360°"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Experience our exquisite craftsmanship from every angle. Rotate, zoom, and explore every detail.</p>"
    },
    {
      "type": "header",
      "content": "3D Model Settings"
    },
    {
      "type": "select",
      "id": "viewer_type",
      "label": "Viewer Type",
      "options": [
        {
          "value": "standard",
          "label": "Standard (Model Viewer)"
        },
        {
          "value": "webgi",
          "label": "Advanced (WebGI - Better Reflections)"
        }
      ],
      "default": "standard",
      "info": "WebGI provides better diamond and metal reflections but requires hosting the viewer separately"
    },
    {
      "type": "text",
      "id": "webgi_viewer_url",
      "label": "WebGI Viewer URL",
      "info": "URL to your hosted WebGI viewer (e.g., https://your-domain.com/ring-viewer/). Only used when Advanced viewer is selected."
    },
    {
      "type": "url",
      "id": "glb_file_url",
      "label": "GLB File URL",
      "info": "Enter the URL to your .glb 3D model file. You can upload the GLB file to Shopify Files or use an external CDN."
    },
    {
      "type": "image_picker",
      "id": "preview_image",
      "label": "Preview Image",
      "info": "Shown before the 3D viewer loads"
    },
    {
      "type": "range",
      "id": "exposure",
      "label": "Model Brightness",
      "min": 0.5,
      "max": 2,
      "step": 0.1,
      "default": 1,
      "info": "Adjust the lighting exposure of the 3D model"
    },
    {
      "type": "header",
      "content": "Button Settings"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "View in 360°"
    },
    {
      "type": "text",
      "id": "modal_title",
      "label": "Modal Title",
      "default": "360° Ring View"
    },
    {
      "type": "checkbox",
      "id": "show_features",
      "label": "Show feature icons",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_ar_button",
      "label": "Show AR button",
      "default": true,
      "info": "Allow users to view in augmented reality on supported devices"
    },
    {
      "type": "header",
      "content": "Style Settings"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#faf9f7"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Section padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Section padding bottom",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Ring 360° Viewer",
      "settings": {
        "heading": "View Our Ring in 360°",
        "subheading": "Interactive Experience",
        "description": "<p>Experience our exquisite craftsmanship from every angle. Rotate, zoom, and explore every detail.</p>"
      }
    }
  ]
}
{% endschema %}
