{% comment %}
  LUXURY COLLECTION GRID - Featured Products
  ==========================================
  Premium product grid with elegant hover effects
  Inspired by Keyzar and high-end jewelry brands
{% endcomment %}

{{ 'luxury-collection-grid.css' | asset_url | stylesheet_tag }}

{% style %}
  #LuxuryGrid-{{ section.id }} {
    --grid-bg: {{ section.settings.background_color }};
    --grid-accent: {{ section.settings.accent_color }};
    --grid-columns: {{ section.settings.columns_desktop }};
  }
{% endstyle %}

<section 
  id="LuxuryGrid-{{ section.id }}"
  class="luxury-section luxury-collection-grid"
  style="background-color: var(--grid-bg);"
>
  <div class="luxury-container">
    <!-- Section Header -->
    {%- if section.settings.heading != blank or section.settings.subtitle != blank -%}
      <div class="luxury-collection-grid__header luxury-reveal">
        {%- if section.settings.subtitle != blank -%}
          <p class="luxury-collection-grid__subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}
        
        {%- if section.settings.heading != blank -%}
          <h2 class="luxury-collection-grid__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        
        <div class="luxury-divider"></div>
        
        {%- if section.settings.description != blank -%}
          <p class="luxury-collection-grid__description">{{ section.settings.description }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <!-- Product Grid -->
    <div class="luxury-collection-grid__products luxury-stagger">
      {%- if section.settings.collection != blank -%}
        {%- assign collection = section.settings.collection -%}
        {%- for product in collection.products limit: section.settings.products_to_show -%}
          <div class="luxury-product-card" data-product-handle="{{ product.handle }}">
            <a href="{{ product.url }}" class="luxury-product-card__link">
              <!-- Media Container -->
              <div class="luxury-product-card__media">
                {%- if product.featured_media -%}
                  <img 
                    src="{{ product.featured_media | image_url: width: 600 }}"
                    srcset="{{ product.featured_media | image_url: width: 400 }} 400w, {{ product.featured_media | image_url: width: 600 }} 600w, {{ product.featured_media | image_url: width: 800 }} 800w"
                    sizes="(min-width: 1024px) 25vw, (min-width: 768px) 33vw, 50vw"
                    alt="{{ product.featured_media.alt | escape | default: product.title }}"
                    loading="lazy"
                    class="luxury-product-card__image luxury-product-card__image--primary"
                    width="{{ product.featured_media.width }}"
                    height="{{ product.featured_media.height }}"
                  >
                  {%- if product.media.size > 1 and section.settings.show_secondary_image -%}
                    <img 
                      src="{{ product.media[1] | image_url: width: 600 }}"
                      alt="{{ product.media[1].alt | escape | default: product.title }}"
                      loading="lazy"
                      class="luxury-product-card__image luxury-product-card__image--secondary"
                      width="{{ product.media[1].width }}"
                      height="{{ product.media[1].height }}"
                    >
                  {%- endif -%}
                {%- else -%}
                  <div class="luxury-product-card__placeholder">
                    {{ 'product-1' | placeholder_svg_tag }}
                  </div>
                {%- endif -%}

                <!-- Quick Actions -->
                {%- if section.settings.show_quick_add -%}
                  <div class="luxury-product-card__actions">
                    <button 
                      type="button"
                      class="luxury-product-card__quick-add"
                      data-product-url="{{ product.url }}"
                      aria-label="Quick view {{ product.title }}"
                    >
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="12" y1="8" x2="12" y2="16"/>
                        <line x1="8" y1="12" x2="16" y2="12"/>
                      </svg>
                      <span>Quick View</span>
                    </button>
                  </div>
                {%- endif -%}

                <!-- Badges -->
                <div class="luxury-product-card__badges">
                  {%- if product.available == false -%}
                    <span class="luxury-product-card__badge luxury-product-card__badge--soldout">Sold Out</span>
                  {%- elsif product.compare_at_price > product.price -%}
                    {%- assign savings = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
                    <span class="luxury-product-card__badge luxury-product-card__badge--sale">{{ savings }}% Off</span>
                  {%- endif -%}
                  
                  {%- for tag in product.tags -%}
                    {%- if tag == 'new' or tag == 'New' -%}
                      <span class="luxury-product-card__badge luxury-product-card__badge--new">New</span>
                    {%- endif -%}
                    {%- if tag == 'bestseller' or tag == 'Bestseller' -%}
                      <span class="luxury-product-card__badge luxury-product-card__badge--bestseller">Bestseller</span>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              </div>

              <!-- Content -->
              <div class="luxury-product-card__content">
                {%- if section.settings.show_vendor and product.vendor != blank -%}
                  <p class="luxury-product-card__vendor">{{ product.vendor }}</p>
                {%- endif -%}
                
                <h3 class="luxury-product-card__title">{{ product.title }}</h3>
                
                <!-- Product Specs (if jewelry) -->
                {%- if product.metafields.custom.metal != blank or product.metafields.custom.carat != blank -%}
                  <p class="luxury-product-card__specs">
                    {%- if product.metafields.custom.metal != blank -%}
                      {{ product.metafields.custom.metal }}
                    {%- endif -%}
                    {%- if product.metafields.custom.carat != blank -%}
                      {%- if product.metafields.custom.metal != blank -%} · {% endif -%}
                      {{ product.metafields.custom.carat }}ct
                    {%- endif -%}
                  </p>
                {%- endif -%}

                <div class="luxury-product-card__price">
                  {%- if product.compare_at_price > product.price -%}
                    <span class="luxury-product-card__price-compare">{{ product.compare_at_price | money }}</span>
                  {%- endif -%}
                  <span class="luxury-product-card__price-current">{{ product.price | money }}</span>
                </div>
              </div>
            </a>
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..4) -%}
          <div class="luxury-product-card luxury-product-card--placeholder">
            <div class="luxury-product-card__media">
              <div class="luxury-product-card__placeholder">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            </div>
            <div class="luxury-product-card__content">
              <h3 class="luxury-product-card__title">Product Title</h3>
              <div class="luxury-product-card__price">
                <span class="luxury-product-card__price-current">$1,299</span>
              </div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    <!-- View All Link -->
    {%- if section.settings.show_view_all and section.settings.collection != blank -%}
      <div class="luxury-collection-grid__footer luxury-reveal">
        <a href="{{ section.settings.collection.url }}" class="luxury-btn luxury-btn--{{ section.settings.view_all_style }}">
          {{ section.settings.view_all_text | default: 'View Collection' }}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

<script>
  // Intersection Observer for reveal animations
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.querySelector('#LuxuryGrid-{{ section.id }}');
    if (!section) return;
    
    const reveals = section.querySelectorAll('.luxury-reveal, .luxury-stagger');
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, {
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px'
    });
    
    reveals.forEach(el => observer.observe(el));
  });
</script>

{% schema %}
{
  "name": "Luxury Collection Grid",
  "tag": "section",
  "class": "luxury-collection-grid-section",
  "settings": [
    {
      "type": "header",
      "content": "Collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4,
      "label": "Products to show"
    },
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Curated Selection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Engagement Rings"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4,
      "label": "Columns on desktop"
    },
    {
      "type": "header",
      "content": "Product Cards"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "label": "Show secondary image on hover",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_quick_add",
      "label": "Show quick view button",
      "default": true
    },
    {
      "type": "header",
      "content": "View All"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View All' button",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "Button text",
      "default": "View Collection"
    },
    {
      "type": "select",
      "id": "view_all_style",
      "label": "Button style",
      "options": [
        { "value": "primary", "label": "Primary (Black)" },
        { "value": "secondary", "label": "Secondary (Outline)" },
        { "value": "gold", "label": "Gold" }
      ],
      "default": "secondary"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#c9a962"
    }
  ],
  "presets": [
    {
      "name": "Luxury Collection Grid",
      "settings": {
        "subtitle": "Curated Selection",
        "heading": "Engagement Rings",
        "products_to_show": 4
      }
    }
  ]
}
{% endschema %}
