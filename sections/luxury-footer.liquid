{% comment %}
  LUXURY FOOTER - Premium Style
  =============================
  Elegant footer with newsletter, links, and trust badges
{% endcomment %}

{{ 'luxury-footer.css' | asset_url | stylesheet_tag }}

{% style %}
  #LuxuryFooter-{{ section.id }} {
    --footer-bg: {{ section.settings.background_color }};
    --footer-text: {{ section.settings.text_color }};
    --footer-accent: {{ section.settings.accent_color }};
  }
{% endstyle %}

<footer 
  id="LuxuryFooter-{{ section.id }}"
  class="luxury-footer"
  style="background-color: var(--footer-bg); color: var(--footer-text);"
>
  <!-- Newsletter Section -->
  {%- if section.settings.show_newsletter -%}
    <div class="luxury-footer__newsletter">
      <div class="luxury-container">
        <div class="luxury-footer__newsletter-inner">
          <div class="luxury-footer__newsletter-content">
            {%- if section.settings.newsletter_heading != blank -%}
              <h2 class="luxury-footer__newsletter-heading">{{ section.settings.newsletter_heading }}</h2>
            {%- endif -%}
            {%- if section.settings.newsletter_text != blank -%}
              <p class="luxury-footer__newsletter-text">{{ section.settings.newsletter_text }}</p>
            {%- endif -%}
          </div>
          
          <div class="luxury-footer__newsletter-form">
            {%- form 'customer', class: 'luxury-newsletter-form' -%}
              <input type="hidden" name="contact[tags]" value="newsletter">
              <div class="luxury-newsletter-form__group">
                <input 
                  type="email" 
                  name="contact[email]" 
                  class="luxury-newsletter-form__input"
                  placeholder="Enter your email"
                  required
                  aria-label="Email address"
                  autocomplete="email"
                >
                <button type="submit" class="luxury-newsletter-form__submit">
                  <span>Subscribe</span>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </button>
              </div>
              <p class="luxury-newsletter-form__note">{{ section.settings.newsletter_note }}</p>
            {%- endform -%}
          </div>
        </div>
      </div>
    </div>
  {%- endif -%}

  <!-- Main Footer -->
  <div class="luxury-footer__main">
    <div class="luxury-container">
      <div class="luxury-footer__grid">
        <!-- Brand Column -->
        <div class="luxury-footer__brand">
          {%- if section.settings.logo != blank -%}
            <a href="{{ routes.root_url }}" class="luxury-footer__logo">
              <img 
                src="{{ section.settings.logo | image_url: width: 300 }}"
                alt="{{ shop.name }}"
                width="{{ section.settings.logo_width }}"
                height="auto"
                loading="lazy"
              >
            </a>
          {%- else -%}
            <a href="{{ routes.root_url }}" class="luxury-footer__logo-text">{{ shop.name }}</a>
          {%- endif -%}
          
          {%- if section.settings.brand_text != blank -%}
            <p class="luxury-footer__brand-text">{{ section.settings.brand_text }}</p>
          {%- endif -%}

          <!-- Social Links -->
          {%- if section.settings.show_social -%}
            <div class="luxury-footer__social">
              {%- if settings.social_instagram_link != blank -%}
                <a href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener" aria-label="Instagram" class="luxury-footer__social-link">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <rect x="2" y="2" width="20" height="20" rx="5"/>
                    <circle cx="12" cy="12" r="4"/>
                    <circle cx="18" cy="6" r="1" fill="currentColor"/>
                  </svg>
                </a>
              {%- endif -%}
              {%- if settings.social_facebook_link != blank -%}
                <a href="{{ settings.social_facebook_link }}" target="_blank" rel="noopener" aria-label="Facebook" class="luxury-footer__social-link">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
                  </svg>
                </a>
              {%- endif -%}
              {%- if settings.social_pinterest_link != blank -%}
                <a href="{{ settings.social_pinterest_link }}" target="_blank" rel="noopener" aria-label="Pinterest" class="luxury-footer__social-link">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <circle cx="12" cy="12" r="10"/>
                    <path d="M8 12c0-2.2 1.8-4 4-4s4 1.8 4 4-1.8 4-4 4"/>
                    <path d="M12 12l-2 8"/>
                  </svg>
                </a>
              {%- endif -%}
              {%- if settings.social_youtube_link != blank -%}
                <a href="{{ settings.social_youtube_link }}" target="_blank" rel="noopener" aria-label="YouTube" class="luxury-footer__social-link">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <rect x="2" y="4" width="20" height="16" rx="2"/>
                    <polygon points="10 9 15 12 10 15" fill="currentColor"/>
                  </svg>
                </a>
              {%- endif -%}
              {%- if settings.social_tiktok_link != blank -%}
                <a href="{{ settings.social_tiktok_link }}" target="_blank" rel="noopener" aria-label="TikTok" class="luxury-footer__social-link">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/>
                  </svg>
                </a>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>

        <!-- Navigation Columns -->
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'link_list' -%}
              <div class="luxury-footer__column" {{ block.shopify_attributes }}>
                {%- if block.settings.heading != blank -%}
                  <h3 class="luxury-footer__column-title">{{ block.settings.heading }}</h3>
                {%- endif -%}
                
                {%- if block.settings.menu != blank -%}
                  <ul class="luxury-footer__links">
                    {%- for link in linklists[block.settings.menu].links -%}
                      <li>
                        <a href="{{ link.url }}" class="luxury-footer__link">{{ link.title }}</a>
                      </li>
                    {%- endfor -%}
                  </ul>
                {%- endif -%}
              </div>

            {%- when 'text' -%}
              <div class="luxury-footer__column" {{ block.shopify_attributes }}>
                {%- if block.settings.heading != blank -%}
                  <h3 class="luxury-footer__column-title">{{ block.settings.heading }}</h3>
                {%- endif -%}
                
                {%- if block.settings.text != blank -%}
                  <div class="luxury-footer__text">{{ block.settings.text }}</div>
                {%- endif -%}
              </div>

            {%- when 'contact' -%}
              <div class="luxury-footer__column luxury-footer__column--contact" {{ block.shopify_attributes }}>
                {%- if block.settings.heading != blank -%}
                  <h3 class="luxury-footer__column-title">{{ block.settings.heading }}</h3>
                {%- endif -%}
                
                <ul class="luxury-footer__contact-list">
                  {%- if block.settings.phone != blank -%}
                    <li>
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                      </svg>
                      <a href="tel:{{ block.settings.phone | remove: ' ' }}">{{ block.settings.phone }}</a>
                    </li>
                  {%- endif -%}
                  {%- if block.settings.email != blank -%}
                    <li>
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                        <polyline points="22,6 12,13 2,6"/>
                      </svg>
                      <a href="mailto:{{ block.settings.email }}">{{ block.settings.email }}</a>
                    </li>
                  {%- endif -%}
                  {%- if block.settings.address != blank -%}
                    <li>
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                        <circle cx="12" cy="10" r="3"/>
                      </svg>
                      <span>{{ block.settings.address }}</span>
                    </li>
                  {%- endif -%}
                </ul>
              </div>
          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  <!-- Trust Badges -->
  {%- if section.settings.show_trust_badges -%}
    <div class="luxury-footer__trust">
      <div class="luxury-container">
        <div class="luxury-footer__trust-inner">
          <div class="luxury-footer__trust-badge">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
            <span>Secure Payments</span>
          </div>
          <div class="luxury-footer__trust-badge">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="1" y="3" width="15" height="13" rx="2"/>
              <path d="M16 8h5l3 3v5a2 2 0 0 1-2 2h-2"/>
              <circle cx="5.5" cy="18.5" r="2.5"/>
              <circle cx="18.5" cy="18.5" r="2.5"/>
            </svg>
            <span>Free Shipping</span>
          </div>
          <div class="luxury-footer__trust-badge">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            <span>30-Day Returns</span>
          </div>
          <div class="luxury-footer__trust-badge">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/>
              <path d="M2 17l10 5 10-5"/>
              <path d="M2 12l10 5 10-5"/>
            </svg>
            <span>Lifetime Warranty</span>
          </div>
        </div>
      </div>
    </div>
  {%- endif -%}

  <!-- Bottom Bar -->
  <div class="luxury-footer__bottom">
    <div class="luxury-container">
      <div class="luxury-footer__bottom-inner">
        <p class="luxury-footer__copyright">
          &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.
        </p>
        
        {%- if section.settings.show_payment_icons -%}
          <div class="luxury-footer__payment">
            {{ shop.enabled_payment_types | payment_type_svg_tag }}
          </div>
        {%- endif -%}
        
        <div class="luxury-footer__policies">
          {%- for link in linklists.footer.links -%}
            {%- if link.title contains 'Privacy' or link.title contains 'Terms' or link.title contains 'Refund' -%}
              <a href="{{ link.url }}" class="luxury-footer__policy-link">{{ link.title }}</a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Luxury Footer",
  "tag": "section",
  "class": "luxury-footer-section",
  "settings": [
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Show newsletter signup",
      "default": true
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter heading",
      "default": "Join Our World"
    },
    {
      "type": "textarea",
      "id": "newsletter_text",
      "label": "Newsletter text",
      "default": "Be the first to discover new collections, exclusive offers, and jewelry inspiration."
    },
    {
      "type": "text",
      "id": "newsletter_note",
      "label": "Newsletter note",
      "default": "By subscribing, you agree to receive marketing emails. Unsubscribe anytime."
    },
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 80,
      "max": 250,
      "step": 10,
      "default": 150,
      "unit": "px",
      "label": "Logo width"
    },
    {
      "type": "textarea",
      "id": "brand_text",
      "label": "Brand description",
      "default": "Crafting timeless pieces that celebrate life's most precious moments since 1985."
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show social media links",
      "default": true,
      "info": "Configure social links in Theme Settings"
    },
    {
      "type": "header",
      "content": "Trust & Payments"
    },
    {
      "type": "checkbox",
      "id": "show_trust_badges",
      "label": "Show trust badges",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show payment icons",
      "default": true
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#0a0a0a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#c9a962"
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Link List",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Shop"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text"
        }
      ]
    },
    {
      "type": "contact",
      "name": "Contact Info",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Contact Us"
        },
        {
          "type": "text",
          "id": "phone",
          "label": "Phone number",
          "default": "+1 (800) 555-0123"
        },
        {
          "type": "text",
          "id": "email",
          "label": "Email",
          "default": "hello@example.com"
        },
        {
          "type": "textarea",
          "id": "address",
          "label": "Address"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "link_list",
        "settings": {
          "heading": "Shop"
        }
      },
      {
        "type": "link_list",
        "settings": {
          "heading": "Customer Care"
        }
      },
      {
        "type": "contact",
        "settings": {
          "heading": "Contact Us"
        }
      }
    ]
  }
}
{% endschema %}
